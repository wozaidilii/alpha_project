page {
  min-height: 100vh;
  color: #1f2a29;
  background: #f5f1e8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

button {
  box-sizing: border-box;
  border-radius: 8px;
  font-weight: 600;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 32rpx;
}

.eyebrow {
  color: #8f3b28;
  font-size: 24rpx;
  letter-spacing: 0;
}

.title {
  margin-top: 12rpx;
  color: #102522;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.1;
}

.subtitle {
  margin-top: 20rpx;
  color: #54615f;
  font-size: 28rpx;
  line-height: 1.6;
}

.primary-button {
  width: 100%;
  height: 96rpx;
  margin-top: 32rpx;
  border: 0;
  color: #f9f5ea;
  background: #15332f;
  font-size: 30rpx;
  line-height: 96rpx;
}

.secondary-button {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  border: 2rpx solid #b9aa8b;
  color: #15332f;
  background: transparent;
  font-size: 28rpx;
  line-height: 84rpx;
}

.status-text {
  margin-top: 28rpx;
  color: #8f3b28;
  font-size: 26rpx;
  line-height: 1.5;
}
