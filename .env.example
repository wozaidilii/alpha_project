DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Baidu Maps JS API AK, used by 图寻模式 panorama.
NEXT_PUBLIC_BAIDU_MAP_AK=""

# Google Maps JS API key, used by 国外模式 and 猜动漫模式 map guessing.
NEXT_PUBLIC_GOOGLE_MAP_AK=""

# Public image URL prefix for 猜动漫模式.
# The URL must be browser-readable without Authorization.
# Upload with: npm run images:upload-anime -- <local-file> <object-key>
NEXT_PUBLIC_ANIME_GUESSR_IMAGE_BASE_URL="https://pub-fb0cf55dbd0b4c4cb42bf8312f34dbd4.r2.dev"

# Resend 邮件验证码（生产环境重置密码必需）
RESEND_API_KEY=""
EMAIL_FROM="AniGuessr <noreply@loamly.net>"
EMAIL_VERIFICATION_SECRET=""

# Google OAuth（可选登录方式）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://loamly.net/api/auth/google/callback"

# PostHog（可选埋点）
# 推荐使用 PostHog 官方 Next.js 文档变量名 NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN；
# NEXT_PUBLIC_POSTHOG_KEY 继续兼容旧部署。
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Vercel Blob（本地 images:upload 脚本）
# 方式一（推荐本地）：从 Blob Store Settings 复制 Read-Write Token
# BLOB_READ_WRITE_TOKEN=""
# 方式二：vercel env pull 后自动获得（需 Blob Store 开启 Development OIDC）
# BLOB_STORE_ID=""
# VERCEL_OIDC_TOKEN=""
# BLOB_ACCESS="private"
